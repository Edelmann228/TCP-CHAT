<Window x:Class="ChatServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TCP Чат — Сервер" Height="520" Width="680"
        Closing="Window_Closing">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Строка 0: управление -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <TextBlock Text="Порт:" VerticalAlignment="Center" Margin="0,0,5,0" FontSize="14"/>
            <TextBox x:Name="TxtPort" Text="5000" Width="70" FontSize="14"
                     VerticalAlignment="Center" Padding="4,2"/>
            <Button x:Name="BtnStart" Content="▶ Запустить" Width="120" Margin="10,0,5,0"
                    FontSize="13" Click="BtnStart_Click"
                    Background="#388E3C" Foreground="White" BorderThickness="0" Padding="8,4"/>
            <Button x:Name="BtnStop" Content="■ Остановить" Width="120" IsEnabled="False"
                    FontSize="13" Click="BtnStop_Click"
                    Background="#D32F2F" Foreground="White" BorderThickness="0" Padding="8,4"/>
        </StackPanel>

        <!-- Строка 1: счётчик -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
            <Label x:Name="LblCount" Content="Клиентов: 0" FontSize="13" FontWeight="Bold" Padding="0"/>
        </StackPanel>

        <!-- Строка 2: лог -->
        <ListBox x:Name="ListLog" Grid.Row="2"
                 FontFamily="Consolas" FontSize="12"
                 Background="#212121" Foreground="#F5F5F5"
                 BorderThickness="1" BorderBrush="#555"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>

        <!-- Строка 3: статус -->
        <Label x:Name="LblStatus" Grid.Row="3" Content="Статус: остановлен"
               FontSize="12" Foreground="Gray" Margin="0,4,0,0" Padding="0"/>
    </Grid>
</Window>
